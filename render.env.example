# Render environment variables (example) — set these in Render dashboard for the service
PORT=4000
MONGO_URI=mongodb+srv://REDACTED:REDACTED@REDACTED.mongodb.net/konpuk?retryWrites=true&w=majority
CLIENT_ORIGIN=https://konpuk.com
# Supported frontend env names (the server reads any of these):
# CLIENT_URL, CLIENT_ORIGIN, FRONTEND_URL, FRONTEND
# Primary production value should be https://konpuk.com
# The server also allows https://www.konpuk.com by default.
JWT_SECRET=REDACTED
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=no-reply@konpuk.com
UPLOAD_DIR=uploads
NODE_ENV=production
